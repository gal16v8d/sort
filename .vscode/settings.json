{
    "editor.formatOnSave": true,

    "[python]": {
        // Look for formatters in system/Poetry path
        "editor.defaultFormatter": "ms-python.python",
        "editor.formatOnSaveMode": "file"
    },

    "pylint.args": [
        "--rcfile=${workspaceFolder}/.pylintrc"
    ],
    "pylint.ignorePatterns": [
        ".vscode/*.py",
        "**/site-packages/**/*.py"
    ]
}